generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model GroceryItem {
  id        String   @id @default(cuid())
  name      String
  quantity  Int      @default(1)
  checked   Boolean  @default(false)
  createdAt DateTime @default(now())
}

model ShareLink {
  id        String   @id @default(cuid())
  token     String   @unique
  createdAt DateTime @default(now())
}
